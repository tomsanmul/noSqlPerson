type Person {
  id: ID!
  operation: String!
  name: String!
  age: Int!
  email: String
  createdAt: String
  updatedAt: String
}

type Query {
  allPersons: [Person!]!
  personByKey(id: ID!, operation: String!): Person
}

input person {
  id: ID
  operation: String!
  name: String!
  age: Int!
  email: String
}

type Mutation {
  savePerson(person: person!): Person
  deletePersonByKey(id: ID!, operation: String!): Person
  updatePersonByKey(person: person!): Person
}